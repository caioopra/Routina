#!/usr/bin/env bash
set -e

# Pre-commit hook: check formatting before allowing commits.
# Install with: ./scripts/setup-hooks.sh

REPO_ROOT="$(git rev-parse --show-toplevel)"

# --- Rust formatting ---
RUST_STAGED=$(git diff --cached --name-only --diff-filter=ACM -- '*.rs')
if [ -n "$RUST_STAGED" ]; then
  echo "Checking Rust formatting..."
  if ! (cd "$REPO_ROOT/backend" && cargo fmt -- --check) ; then
    echo ""
    echo "Rust formatting check failed."
    echo "Run 'cd backend && cargo fmt' to fix, then stage the changes."
    exit 1
  fi
fi

# --- sqlx offline metadata drift ---
# When staged Rust changes touch a sqlx::query*! macro, verify the committed
# .sqlx/ metadata still matches the live schema. This is the single most
# important guard against runtime-only drift (migration changes that leave
# query TEXT unchanged but the inferred column types stale). The hook will
# auto-start the local DB via docker compose and apply migrations so the
# check is always authoritative.
#
# Escape hatch: `SKIP_SQLX_CHECK=1 git commit …` to bypass (CI will still catch it).
if [ -n "$RUST_STAGED" ] && [ "${SKIP_SQLX_CHECK:-0}" != "1" ]; then
  SQLX_STAGED=$(git diff --cached --diff-filter=ACM -U0 -- '*.rs' | grep -E '^\+.*sqlx::query' || true)
  MIGRATIONS_STAGED=$(git diff --cached --name-only --diff-filter=ACMD -- 'backend/migrations/*.sql' || true)

  if [ -n "$SQLX_STAGED" ] || [ -n "$MIGRATIONS_STAGED" ]; then
    echo "Checking sqlx offline metadata..."

    # Source backend/.env for DATABASE_URL (if present and DATABASE_URL not already set)
    if [ -z "${DATABASE_URL:-}" ] && [ -f "$REPO_ROOT/backend/.env" ]; then
      # shellcheck disable=SC1091
      set -a; . "$REPO_ROOT/backend/.env"; set +a
    fi
    export DATABASE_URL="${DATABASE_URL:-postgres://planner:planner@localhost:5432/planner}"

    # 1. sqlx-cli available?
    if ! cargo sqlx --version >/dev/null 2>&1 ; then
      echo ""
      echo "sqlx-cli is required to verify offline metadata."
      echo "Install: cargo install sqlx-cli --locked --no-default-features --features native-tls,postgres"
      echo "Or bypass: SKIP_SQLX_CHECK=1 git commit …"
      exit 1
    fi

    # 2. DB reachable? If not, try `docker compose up -d postgres`.
    if ! (cd "$REPO_ROOT/backend" && cargo sqlx migrate run >/dev/null 2>&1) ; then
      if command -v docker >/dev/null 2>&1 ; then
        echo "  Postgres unreachable — starting via docker compose…"
        (cd "$REPO_ROOT" && docker compose up -d postgres >/dev/null 2>&1) || true
        for _ in $(seq 1 30); do
          (cd "$REPO_ROOT/backend" && cargo sqlx migrate run >/dev/null 2>&1) && break
          sleep 1
        done
      fi
      if ! (cd "$REPO_ROOT/backend" && cargo sqlx migrate run >/dev/null 2>&1) ; then
        echo ""
        echo "Cannot reach Postgres at $DATABASE_URL."
        echo "Start it with 'make db-up' or bypass with SKIP_SQLX_CHECK=1 git commit …"
        exit 1
      fi
    fi

    # 3. Authoritative drift check against the migrated DB.
    if ! (cd "$REPO_ROOT/backend" && SQLX_OFFLINE=false cargo sqlx prepare --workspace --check -- --all-targets >/dev/null 2>&1) ; then
      echo ""
      echo "sqlx offline metadata (backend/.sqlx/) is out of date."
      echo "Run 'make prepare' and stage the updated backend/.sqlx/ files."
      exit 1
    fi
  fi
fi

# --- Frontend formatting ---
JS_STAGED=$(git diff --cached --name-only --diff-filter=ACM -- '*.js' '*.jsx' '*.ts' '*.tsx' '*.css' '*.json' | grep '^frontend/' || true)
if [ -n "$JS_STAGED" ]; then
  # Strip the frontend/ prefix so paths resolve from the frontend directory
  JS_RELATIVE=$(echo "$JS_STAGED" | sed 's|^frontend/||')
  echo "Checking frontend formatting..."
  if ! (cd "$REPO_ROOT/frontend" && npx prettier --check $JS_RELATIVE) ; then
    echo ""
    echo "Frontend formatting check failed."
    echo "Run 'cd frontend && npm run format' to fix, then stage the changes."
    exit 1
  fi
fi

echo "Formatting checks passed."
